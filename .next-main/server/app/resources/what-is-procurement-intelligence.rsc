0:["DQJrIey0yv3zvSj9T5n-e",[[["",{"children":["resources",{"children":["what-is-procurement-intelligence",{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",{"children":["resources",{"children":["what-is-procurement-intelligence",{"children":["__PAGE__",{},[["$L1",[["$","section",null,{"id":"$undefined","className":"section  hero-block hero-section","children":["$","div",null,{"className":"page-container","children":[["$","p",null,{"className":"eyebrow","children":"Resources"}],["$","h1",null,{"className":"headline-xl","children":"What Is Procurement Intelligence?"}],["$","p",null,{"className":"text-lead","children":"Procurement intelligence is the discipline of turning procurement history, contract lifecycle context, and market participation data into structured planning signals for commercial teams."}]]}]}],["$","section",null,{"id":"$undefined","className":"section section-muted","children":["$","div",null,{"className":"page-container","children":["$","div",null,{"className":"article-shell","children":[["$","article",null,{"className":"card article-card","children":[["$","h2",null,{"className":"headline-lg article-heading","children":"Procurement intelligence in practice"}],["$","p",null,{"className":"article-copy","children":"In public-sector markets, opportunity timing determines preparation quality. Procurement intelligence focuses on identifying where demand is likely to emerge before tender publication, so teams can prioritize accounts, align partnerships, and allocate resources earlier."}],["$","p",null,{"className":"article-copy","children":"This is not guesswork. It is evidence-based analysis of buying patterns, contract windows, and participation dynamics over time."}]]}],["$","article",null,{"className":"card article-card","children":[["$","h2",null,{"className":"headline-lg article-heading","children":"Why tender monitoring tools are limited"}],["$","p",null,{"className":"article-copy","children":"Traditional tender monitoring platforms are useful for tracking published opportunities. Their limitation is timing: they are strongest after publication, when planning windows are already compressed and engagement options are narrower."}],["$","p",null,{"className":"article-copy","children":"Procurement intelligence adds a pre-publication layer. Instead of only surfacing new notices, it helps teams understand cycle behavior and emerging opportunity signals before formal release."}]]}],["$","article",null,{"className":"card article-card","children":[["$","h2",null,{"className":"headline-lg article-heading","children":"How procurement cycles shape public-sector markets"}],["$","p",null,{"className":"article-copy","children":"Public-sector buying is cyclical. Institutions buy, renew, and retender through repeatable patterns influenced by contract structures, category norms, and internal planning rhythms."}],["$","p",null,{"className":"article-copy","children":"Teams that understand cycle patterns can prepare earlier and make better prioritization decisions. Teams relying only on publication alerts often react too late."}]]}],["$","article",null,{"className":"card article-card","children":[["$","h2",null,{"className":"headline-lg article-heading","children":"Where Civant fits"}],["$","p",null,{"className":"article-copy","children":"Civant is built as a procurement intelligence platform centered on procurement-cycle analysis. It combines historical procurement records, contract lifecycle signals, and market participation data into actionable workflows for enterprise teams."}],["$","p",null,{"className":"article-copy","children":["Explore how Civant modules work on the"," ",["$","$L2",null,{"href":"/platform","className":"text-link","children":"Platform page"}]," ","and review the analytical foundation on the"," ",["$","$L2",null,{"href":"/methodology","className":"text-link","children":"Methodology page"}],"."]}]]}],["$","div",null,{"className":"button-row","children":[["$","$L2",null,{"href":"/resources",