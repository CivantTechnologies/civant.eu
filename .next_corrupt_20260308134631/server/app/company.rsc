copy","children":"The underlying issue was structural: public procurement data exists, but it has not been consistently usable, connected, or organized for proactive decision-making."}],["$","blockquote",null,{"className":"company-quote","children":[["$","p",null,{"className":"company-quote-text","children":"\"When preparation replaces reaction, tenders stop being feared and start becoming a viable, repeatable path to growth.\""}],["$","p",null,{"className":"company-quote-meta","children":["— David Manrique",["$","br",null,{}],"Founder, Civant"]}]]}],["$","a",null,{"href":"https://www.linkedin.com/in/davidmanriquec/","target":"_blank","rel":"noopener noreferrer","className":"text-link company-link","children":"View David Manrique on LinkedIn →"}]]}]}]}],["$","section",null,{"id":"$undefined","className":"section","children":["$","div",null,{"className":"page-container","children":["$","div",null,{"className":"section-heading-wrap company-reading","children":[["$","p",null,{"className":"eyebrow","children":"Mission"}],["$","h2",null,{"className":"headline-lg","children":"What Civant is built to do"}],["$","p",null,{"className":"card-body section-intro company-copy","children":"Civant exists to transform complex public procurement processes into structured, confident, and well-timed decisions for suppliers, buyers, and the public sector."}]]}]}]}],["$","section",null,{"id":"$undefined","className":"section section-muted","children":["$","div",null,{"className":"page-container","children":["$","div",null,{"className":"section-heading-wrap company-reading","children":[["$","p",null,{"className":"eyebrow","children":"Why This Matters"}],["$","h2",null,{"className":"headline-lg","children":"Procurement intelligence has system-level impact"}],["$","p",null,{"className":"card-body section-intro company-copy","children":"Public procurement is designed to support fair competition, stronger outcomes, and responsible use of public funds."}],["$","p",null,{"className":"card-body company-copy","children":"When preparation time is uneven and timing visibility is poor, those goals weaken: capable suppliers are excluded, buyers receive fewer high-quality responses, and public value is reduced."}],["$","p",null,{"className":"card-body company-copy","children":"Making timing visible helps teams compete on merit rather than reaction speed, improves planning quality, and supports healthier market participation."}]]}]}]}],["$","section",null,{"id":"$undefined","className":"section","children":["$","div",null,{"className":"page-container","children":[["$","div",null,{"className":"section-heading-wrap","children":[["$","p",null,{"className":"eyebrow","children":"Commitment to Transparency"}],["$","h2",null,{"className":"headline-lg","children":"How Civant defines its role"}]]}],["$","div",null,{"className":"grid grid-2 company-trust-grid","children":[["$","article",null,{"className":"card company-trust-card","children":[["$","h3",null,{"className":"card-title","children":"What Civant is"}],["$","ul",null,{"className":"stack-list coverage-list","children":[["$","li","Civant brings visibility to public procurement opportunities.",{"children":"Civant brings visibility to public procurement opportunities."}],["$","li","Civant reconciles and normalizes data from EU and national procurement sources.",{"children":"Civant reconciles and normalizes data from EU and national procurement sources."}],["$","li","Civant analyzes publicly available procurement data.",{"children":"Civant analyzes publicly available procurement data."}],["$","li","Civant supports earlier preparation and more intentional planning.",{"children":"Civant supports earlier preparation and more intentional planning."}]]}]]}],["$","article",null,{"className":"card company-trust-card company-trust-card-muted","children":[["$","h3",null,{"className":"card-title","children":"What Civant is not"}],["$","ul",null,{"className":"stack-list coverage-list","children":[["$","li","Civant is not an insi